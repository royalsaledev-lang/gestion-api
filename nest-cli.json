{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "outputPath": "dist",
    "deleteOutDir": true,
    "assets": [
      { "include": "templates/**/*.hbs", "outDir": "dist/src/" }
    ],
    "watchAssets": true
  }
}
