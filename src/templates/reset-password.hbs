<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Réinitialisation du mot de passe</title>
</head>

<body style="margin:0; padding:0; background:#f6f6f6; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="padding:40px 0;">
    <tr>
      <td align="center">

        <!-- CONTAINER -->
        <table width="100%" style="max-width:520px; background:#ffffff; border-radius:14px; overflow:hidden; box-shadow:0 8px 24px rgba(0,0,0,0.06);">

          <!-- HEADER -->
          <tr>
            <td style="background:#000000; padding:24px; text-align:center;">
              <h1 style="color:#ffffff; margin:0; font-size:20px; font-weight:600; letter-spacing:0.5px;">
                Royal Sale Gestion
              </h1>
              <p style="color:#a1a1aa; font-size:12px; margin-top:6px;">
                Plateforme de gestion & collaboration
              </p>
            </td>
          </tr>

          <!-- CONTENT -->
          <tr>
            <td style="padding:32px;">

              <h2 style="margin-top:0; color:#111827; font-size:18px; font-weight:600;">
                Bonjour {{name}},
              </h2>

              <p style="color:#4b5563; line-height:1.6; font-size:14px;">
                Vous avez demandé la réinitialisation de votre mot de passe.
                Cliquez sur le bouton ci-dessous pour définir un nouveau mot de passe.
              </p>

              <!-- BUTTON -->
              <table width="100%" cellpadding="0" cellspacing="0" style="margin:32px 0;">
                <tr>
                  <td align="center">
                    <a href="{{resetLink}}"
                       style="
                         display:inline-block;
                         background:#000000;
                         color:#ffffff;
                         padding:14px 26px;
                         border-radius:8px;
                         text-decoration:none;
                         font-weight:500;
                         font-size:14px;
                         letter-spacing:0.2px;
                       ">
                      Réinitialiser mon mot de passe
                    </a>
                  </td>
                </tr>
              </table>

              <p style="color:#6b7280; font-size:13px;">
                Ce lien expirera dans <strong>15 minutes</strong>.
              </p>

              <p style="color:#9ca3af; font-size:13px;">
                Si vous n'avez pas fait cette demande, vous pouvez ignorer cet email.
              </p>

            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td style="background:#f9fafb; padding:20px; text-align:center;">

              <p style="font-size:12px; color:#6b7280; margin:0;">
                © {{year}} Royal Sale Gestion. Tous droits réservés.
              </p>

              <p style="font-size:11px; color:#9ca3af; margin-top:6px;">
                Email automatique — merci de ne pas répondre.
              </p>

            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>